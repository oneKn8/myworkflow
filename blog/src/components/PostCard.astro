---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  readingTime?: string;
  href: string;
  category?: string;
}

const { title, description, pubDate, tags = [], readingTime, href, category } = Astro.props;

const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<article class="group -mx-3 rounded-lg p-3 transition-all duration-200 hover:bg-(--color-surface)">
  <a href={href} class="block">
    <div class="flex items-center gap-2 text-xs text-(--color-text-muted)">
      <time datetime={pubDate.toISOString()}>{formattedDate}</time>
      {readingTime && (
        <>
          <span class="text-(--color-border-hover)">/</span>
          <span>{readingTime}</span>
        </>
      )}
      {category && (
        <>
          <span class="text-(--color-border-hover)">/</span>
          <span class="capitalize">{category}</span>
        </>
      )}
    </div>
    <h3 class="mt-1.5 text-lg font-semibold text-(--color-text) group-hover:text-(--color-accent) transition-colors">
      {title}
    </h3>
    <p class="mt-1 text-sm text-(--color-text-muted) line-clamp-2 leading-relaxed">
      {description}
    </p>
  </a>
  {tags.length > 0 && (
    <div class="mt-2.5 flex flex-wrap gap-1.5">
      {tags.map((tag) => (
        <a
          href={`/tags/${tag}`}
          class="rounded-md bg-(--color-accent-subtle) px-2 py-0.5 text-xs text-(--color-accent) transition-colors hover:bg-(--color-accent)/20"
        >
          {tag}
        </a>
      ))}
    </div>
  )}
</article>
