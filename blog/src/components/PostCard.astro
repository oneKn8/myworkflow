---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  readingTime?: string;
  href: string;
  category?: string;
}

const { title, description, pubDate, tags = [], readingTime, href, category } = Astro.props;

const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<article class="group border-b border-(--color-border) py-6 first:pt-0 last:border-b-0">
  <a href={href} class="block">
    <div class="flex items-center gap-3 text-sm text-(--color-text-muted)">
      <time datetime={pubDate.toISOString()}>{formattedDate}</time>
      {readingTime && (
        <>
          <span aria-hidden="true">&middot;</span>
          <span>{readingTime}</span>
        </>
      )}
      {category && (
        <>
          <span aria-hidden="true">&middot;</span>
          <span class="capitalize">{category}</span>
        </>
      )}
    </div>
    <h3 class="mt-2 text-xl font-semibold text-(--color-text) group-hover:text-(--color-accent) transition-colors">
      {title}
    </h3>
    <p class="mt-1 text-(--color-text-muted) line-clamp-2">
      {description}
    </p>
  </a>
  {tags.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <a
          href={`/tags/${tag}`}
          class="rounded-full bg-(--color-surface) px-2.5 py-0.5 text-xs text-(--color-text-muted) hover:text-(--color-accent) transition-colors"
        >
          {tag}
        </a>
      ))}
    </div>
  )}
</article>
