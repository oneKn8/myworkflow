---
const year = new Date().getFullYear();
const links = [
  { href: "https://github.com/oneKn8", label: "GitHub" },
  { href: "https://x.com/oneKn8", label: "X" },
  { href: "https://linkedin.com/in/shifat-islam-santo", label: "LinkedIn" },
];
---

<footer class="mt-auto border-t border-(--color-border) py-8">
  <div class="mx-auto flex max-w-3xl flex-col items-center gap-4 px-4 sm:flex-row sm:justify-between">
    <p class="text-sm text-(--color-text-muted)">
      &copy; {year} Shifat Islam Santo
    </p>
    <div class="flex gap-5">
      {links.map(({ href, label }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-(--color-text-muted) hover:text-(--color-text) transition-colors"
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</footer>
