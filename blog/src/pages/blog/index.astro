---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getCollection } from "astro:content";
import { getReadingTime } from "../../utils/reading-time";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog"
  description="Articles about systems engineering, search, audio, infrastructure, and building in the open."
>
  <h1 class="text-3xl font-bold tracking-tight">Blog</h1>
  <p class="mt-2 text-(--color-text-muted)">
    Tutorials, deep dives, and lessons learned.
  </p>

  <div class="mt-8">
    {posts.map((post) => (
      <PostCard
        title={post.data.title}
        description={post.data.description}
        pubDate={post.data.pubDate}
        tags={post.data.tags}
        readingTime={post.body ? getReadingTime(post.body) : undefined}
        href={`/blog/${post.id}`}
        category={post.data.category}
      />
    ))}
  </div>

  {posts.length === 0 && (
    <p class="mt-8 text-(--color-text-muted)">No posts yet. Check back soon.</p>
  )}
</BaseLayout>
